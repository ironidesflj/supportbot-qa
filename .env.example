# ===== General =====
ENVIRONMENT=development

# ===== LLM & Embeddings =====
# Choose the AI engine: 'gemini' (default) or 'openai'
LLM_PROVIDER=gemini

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Google Gemini (only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Models (defaults aligned with app/core/config.py)
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/text-embedding-004

# ===== Web Search fallback (Katzilla) =====
# Optional. If empty, the bot refuses when context is not in the KB.
KATZILLA_API_KEY=

# ===== Vector DB (Qdrant) =====
# Use http://localhost:6333 for local Qdrant via docker-compose,
# or your Qdrant Cloud URL for production.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=supportbot_kb

# ===== RAG Parameters =====
RETRIEVAL_TOP_K=3
SIMILARITY_THRESHOLD=0.75

# ===== CORS (optional) =====
# Comma-separated list of allowed origins. Default: * (all origins).
# Example: CORS_ALLOW_ORIGINS=https://app.vercel.app,https://staging.vercel.app
CORS_ALLOW_ORIGINS=*

# ===== QA Automation (Browser-Use Cloud) =====
# Optional. Only needed to run `python3 run_qa.py`.
# Get a key at https://cloud.browser-use.com
BROWSER_USE_API_KEY=
# Public URL of the app to test (use a tunnel like cloudflared/ngrok if local)
QA_START_URL=
