# ===== General =====
ENVIRONMENT=development

# ===== LLM & Embeddings =====
# Escolha o motor: 'gemini' (padrão) ou 'openai'
LLM_PROVIDER=gemini

# OpenAI (necessário apenas se LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Google Gemini (necessário apenas se LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Modelos (defaults alinhados com app/core/config.py)
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/text-embedding-004

# ===== Web Search fallback (Katzilla) =====
# Opcional. Se vazio, o bot recusa quando não há contexto na KB.
KATZILLA_API_KEY=

# ===== Vector DB (Qdrant) =====
# Use http://localhost:6333 para Qdrant local via docker-compose,
# ou a URL do Qdrant Cloud em produção.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=supportbot_kb

# ===== RAG Parameters =====
RETRIEVAL_TOP_K=3
SIMILARITY_THRESHOLD=0.75
