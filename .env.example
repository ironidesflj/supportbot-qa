# ===== General =====
ENVIRONMENT=development

# ===== LLM & Embeddings =====
# Choose the AI engine: 'gemini' (default) or 'openai'
LLM_PROVIDER=gemini

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Google Gemini (only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Models (defaults aligned with app/core/config.py)
# Chat model: use gemini-2.5-flash if available, else gemini-2.0-flash
# List available models with:
# python3 -c "import google.generativeai as genai; genai.configure(api_key='YOUR_KEY', transport='rest'); [print(m.name) for m in genai.list_models() if 'generateContent' in m.supported_generation_methods]"
LLM_MODEL=gemini-2.5-flash

# Embedding model: gemini-embedding-001 is the current standard (3072 dims).
EMBEDDING_MODEL=models/gemini-embedding-001

# ===== Web Search fallback (Katzilla) =====
# Optional. If empty, the bot refuses when context is not in the KB.
KATZILLA_API_KEY=

# ===== Vector DB (Qdrant) =====
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=supportbot_kb

# ===== RAG Parameters =====
RETRIEVAL_TOP_K=3
# Similarity threshold for vector search. If not set, a sane default is
# used based on EMBEDDING_MODEL (see app/rag/thresholds.py).
# Override only if you need to tune for your specific KB.
SIMILARITY_THRESHOLD=0.40

# ===== Eval Judge (optional) =====
# Model used by the LLM-as-a-Judge in eval/metrics/llm_judge.py.
# Defaults to LLM_MODEL (gemini-2.5-flash) to guarantee compatibility.
# Override only if your key has confirmed quota for an alternative model.
# JUDGE_MODEL=gemini-2.5-flash

# ===== Security =====
# API key required for /api/ingest (X-API-Key header).
# Leave empty for dev mode (no auth). Set in production.
INGEST_API_KEY=

# ===== Rate Limiting (slowapi format: "count/period") =====
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_INGEST=5/minute

# ===== Logging =====
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===== CORS (optional) =====
# Comma-separated list of allowed origins. Default: * (all origins).
CORS_ALLOW_ORIGINS=*

# ===== QA Automation (Browser-Use Cloud) =====
# Optional. Only needed to run python3 run_qa.py.
BROWSER_USE_API_KEY=
QA_START_URL=
