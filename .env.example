# General
ENVIRONMENT=development

# LLM & Embeddings
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
KATZILLA_API_KEY=your_katzilla_api_key_here

# Vector DB (Qdrant)
